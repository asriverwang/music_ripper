# =============================================================================
# music_ripper — configuration template
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Output
# -----------------------------------------------------------------------------

# Root directory where ripped music is saved.
# Structure: {MUSIC_DIR}/{Artist}/{Album}/{NN}_{Title}.mp3
MUSIC_DIR="/media/your_user/data/Music"

# CD/DVD device node. Use `ls /dev/sr*` to find yours.
# CD_DEVICE=/dev/sr0

# -----------------------------------------------------------------------------
# Ripping quality & timeouts
# -----------------------------------------------------------------------------

# Paranoia level for cdparanoia:
#   0 = no error correction (fastest, good for discs in perfect condition)
#   1 = checksums only
#   2 = full paranoia (default, recommended for scratched/worn discs)
# RIP_PARANOIA=2

# Seconds to wait for a single track before killing cdparanoia and retrying.
# Increase if your drive is very slow.
# RIP_TRACK_TIMEOUT=300

# Timeout (seconds) for the retry attempt with paranoia disabled.
# RIP_RETRY_TIMEOUT=120

# -----------------------------------------------------------------------------
# LLM fallback — used when GnuDB and MusicBrainz cannot identify the disc
# Set at least one API key. Only one provider is used per run.
# Auto-detection order: Minimax → OpenAI → Claude
# Override with LLM_PROVIDER=minimax|openai|claude
# -----------------------------------------------------------------------------

# LLM_PROVIDER=minimax

# LLM API request timeout in seconds.
# LLM_TIMEOUT=90

# --- Minimax ---
# Get your key at: https://www.minimaxi.com
# MINIMAX_API_KEY=sk-cp-your_key_here
# MINIMAX_API_URL=https://api.minimax.io/v1/text/chatcompletion_v2
# MINIMAX_MODEL=abab6.5s-chat

# --- OpenAI ---
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_key_here
# OPENAI_MODEL=gpt-4o-mini

# --- Anthropic Claude ---
# Get your key at: https://console.anthropic.com
# CLAUDE_API_KEY=sk-ant-api03-your_key_here
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# -----------------------------------------------------------------------------
# Optional: AcoustID acoustic fingerprinting
# Provides a second identification pass after ripping each track.
# Resolves Unknown Artist/Album via majority vote across all tracks.
# Requires: sudo apt install libchromaprint-tools
# Register free key at: https://acoustid.org/login
# -----------------------------------------------------------------------------

# ACOUSTID_API_KEY=your_key_here

# -----------------------------------------------------------------------------
# Optional: Discogs enrichment
# Adds year, label, and genre ID3 tags after ripping.
# Create a personal access token at: https://www.discogs.com/settings/developers
# -----------------------------------------------------------------------------

# DISCOGS_TOKEN=your_token_here
